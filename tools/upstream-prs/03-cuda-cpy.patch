From 2639461548b68650ebcf37b8f6da2e5e153c3f72 Mon Sep 17 00:00:00 2001
From: CrispStrobe <cze+github@mailbox.org>
Date: Tue, 5 May 2026 08:44:42 +0200
Subject: [PATCH] fix(ggml-cuda): tile transposed cpy along grid_y instead of
 scalar fallback
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

GH issue #65, supersedes the scalar fallback shipped in eb9e4a2.

The transposed cpy kernel asserts grid_y < USHRT_MAX (= 65535), capping
ne00 at < 2,096,640 with CUDA_CPY_TILE_DIM_2D=32. The qwen3-tts codec
graph trips this with [T_pcm, 1, 1, 1] tensors where T_pcm =
T_codec*1920 = 2.88M when QWEN3_TTS_CODEC_GPU=1 and the talker hits its
1500-frame cap.

eb9e4a2 fixed the abort by falling through to the non-transposed scalar
1D-grid kernel. That works but loses the transposed-tile coalescing
optimization for *any* shape that pushes grid_y past USHRT_MAX, even
when the second dim isn't degenerate-1.

Proper fix: tile the kernel launch along the y axis. Add an
y_block_offset parameter to cpy_scalar_transpose; the host loops in
chunks of MAX_GRID_Y = USHRT_MAX-1 and each launch covers a y-slab
[y_block_offset, y_block_offset + grid_y_this). Bit-identical output,
full transposed-tile coalescing preserved on every chunk. For the
common case (grid_y_total <= MAX_GRID_Y) it's a single launch with
y_block_offset=0 — no behavioral change.

Also:
- GGML_LOG_DEBUG when n_chunks > 1 so perf debugging can see when
  tiling kicks in
- GGML_ASSERT(grid_y_total <= INT_MAX) guards the (int)y_off cast
- Audited the rest of ggml-cuda for similar grid asserts: only this
  call site has the USHRT_MAX cap; all the cpy_*_q*_cuda variants use
  1D num_blocks grids gated against UINT_MAX (~4 billion)

Untested on a CUDA host (Mac dev box) — the kernel index math at chunk
boundaries was reviewed for overflow/off-by-one. Reporter (issue #65)
has the Jetson Orin AGX repro to verify against.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 ggml/src/ggml-cuda/cpy.cu | 66 +++++++++++++++++++++++++--------------
 1 file changed, 43 insertions(+), 23 deletions(-)

diff --git a/ggml/src/ggml-cuda/cpy.cu b/ggml/src/ggml-cuda/cpy.cu
index 5422117..77d3421 100644
--- a/ggml/src/ggml-cuda/cpy.cu
+++ b/ggml/src/ggml-cuda/cpy.cu
@@ -43,7 +43,8 @@ template <typename T>
 static __global__ void cpy_scalar_transpose(const char * cx, char * cdst, const int64_t ne,
                                const int64_t ne00, const int64_t ne01, const int64_t ne02, const int64_t nb00, const int64_t nb01, const int64_t nb02,
                                const int64_t nb03, const int64_t ne10, const int64_t ne11, const int64_t ne12, const int64_t nb10, const int64_t nb11,
-                               const int64_t nb12, const int64_t nb13) {
+                               const int64_t nb12, const int64_t nb13,
+                               const int y_block_offset) {
 
     const T* src = reinterpret_cast<const T*>(cx);
     T* dst = reinterpret_cast<T*>(cdst);
@@ -51,9 +52,14 @@ static __global__ void cpy_scalar_transpose(const char * cx, char * cdst, const
     const int64_t nmat = ne / (ne00 * ne01);
     const int64_t n = ne00 * ne01;
 
+    // GH issue #65: large ne00 forces grid_y past the CUDA limit
+    // (USHRT_MAX-1) so the host tiles the launch along blockIdx.y and
+    // passes y_block_offset to splice tiles back into a single logical
+    // grid. For a single launch (the common case) y_block_offset == 0.
+    const int by = blockIdx.y + y_block_offset;
     const int x = blockIdx.x * CUDA_CPY_TILE_DIM_2D + threadIdx.x;
-    const int y = blockIdx.y * CUDA_CPY_TILE_DIM_2D + threadIdx.y;
-    const int tx = blockIdx.y * CUDA_CPY_TILE_DIM_2D + threadIdx.x;  // transpose block offset
+    const int y = by * CUDA_CPY_TILE_DIM_2D + threadIdx.y;
+    const int tx = by * CUDA_CPY_TILE_DIM_2D + threadIdx.x;  // transpose block offset
     const int ty = blockIdx.x * CUDA_CPY_TILE_DIM_2D + threadIdx.y;
 
     __shared__ float tile[2][CUDA_CPY_TILE_DIM_2D][CUDA_CPY_TILE_DIM_2D+1];
@@ -202,8 +208,7 @@ static void ggml_cpy_scalar_cuda(
     const int64_t ne00, const int64_t ne01, const int64_t ne02, const int64_t nb00, const int64_t nb01, const int64_t nb02,
     const int64_t nb03, const int64_t ne10, const int64_t ne11, const int64_t ne12, const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13, cudaStream_t stream) {
 
-    bool use_transposed = transposed;
-    if (use_transposed) {
+    if (transposed) {
         GGML_ASSERT(ne == ne00*ne01*ne02);  // ne[3] is 1 assumed
         int64_t ne00n, ne01n, ne02n;
         if (nb00 <= nb02) { // most likely safe to handle nb00 = nb02 case here
@@ -216,28 +221,43 @@ static void ggml_cpy_scalar_cuda(
             ne02n = 1;
         }
 
-        int64_t grid_x = (ne01n + CUDA_CPY_TILE_DIM_2D - 1) / CUDA_CPY_TILE_DIM_2D;
-        int64_t grid_y = (ne00n + CUDA_CPY_TILE_DIM_2D - 1) / CUDA_CPY_TILE_DIM_2D;
-        int64_t grid_z = (ne/(ne01n*ne00n) + CUDA_CPY_BLOCK_NM - 1) / CUDA_CPY_BLOCK_NM;
+        const int64_t grid_x       = (ne01n + CUDA_CPY_TILE_DIM_2D - 1) / CUDA_CPY_TILE_DIM_2D;
+        const int64_t grid_y_total = (ne00n + CUDA_CPY_TILE_DIM_2D - 1) / CUDA_CPY_TILE_DIM_2D;
+        const int64_t grid_z       = (ne/(ne01n*ne00n) + CUDA_CPY_BLOCK_NM - 1) / CUDA_CPY_BLOCK_NM;
         GGML_ASSERT(grid_x < UINT_MAX);
         GGML_ASSERT(grid_z < USHRT_MAX);
-        // GH issue #65: when ne00 is huge (e.g. qwen3-tts codec
-        // graph emitting [T_pcm, 1, 1, 1] with T_pcm > 2.1M),
-        // grid_y exceeds USHRT_MAX and the kernel launch would
-        // abort. Fall through to the scalar 1D-grid path, which
-        // is gated against UINT_MAX (~4 billion) and produces
-        // bit-identical output, just without the transposed-tile
-        // coalescing optimization.
-        if (grid_y >= USHRT_MAX) {
-            use_transposed = false;
-        } else {
-            dim3 dimGrid(grid_x, grid_y, grid_z);
-            dim3 dimBlock(CUDA_CPY_TILE_DIM_2D, CUDA_CPY_BLOCK_ROWS, 1);
+
+        // GH issue #65: when ne00n is huge (qwen3-tts codec graph
+        // emits [T_pcm, 1, 1, 1] with T_pcm = T_codec * 1920 ≈ 2.88M
+        // when QWEN3_TTS_CODEC_GPU=1 + the talker hits its 1500-frame
+        // cap), the implied grid_y exceeds the CUDA grid-Y limit
+        // (USHRT_MAX = 65535, with the existing assert reserving the
+        // top value). Tile the launch along the y axis: each kernel
+        // covers a [y_block_offset, y_block_offset + grid_y_this) slab
+        // and the kernel splices its blockIdx.y back onto the offset.
+        // Bit-identical output, full transposed-tile coalescing
+        // preserved on every chunk.
+        constexpr int64_t MAX_GRID_Y = USHRT_MAX - 1;  // strictly less than the assert
+        const int64_t n_chunks = (grid_y_total + MAX_GRID_Y - 1) / MAX_GRID_Y;
+        if (n_chunks > 1) {
+            GGML_LOG_DEBUG("ggml_cuda_cpy: tiling transposed cpy along grid_y (ne00n=%lld, grid_y_total=%lld → %lld launches)\n",
+                           (long long)ne00n, (long long)grid_y_total, (long long)n_chunks);
+        }
+        // y_block_offset is int (matches blockIdx.y type domain). For ne00n
+        // pushing grid_y_total past INT_MAX the kernel's existing int-typed
+        // y/ty arithmetic would overflow first, so an explicit assert here
+        // is purely defense-in-depth.
+        GGML_ASSERT(grid_y_total <= INT_MAX);
+        const dim3 dimBlock(CUDA_CPY_TILE_DIM_2D, CUDA_CPY_BLOCK_ROWS, 1);
+        for (int64_t y_off = 0; y_off < grid_y_total; y_off += MAX_GRID_Y) {
+            const int64_t remaining   = grid_y_total - y_off;
+            const int64_t grid_y_this = remaining < MAX_GRID_Y ? remaining : MAX_GRID_Y;
+            const dim3 dimGrid((unsigned int)grid_x, (unsigned int)grid_y_this, (unsigned int)grid_z);
             cpy_scalar_transpose<dst_t><<<dimGrid, dimBlock, 0, stream>>>
-                (cx, cdst, ne, ne00n, ne01n, ne02n, nb00, nb01, nb02, nb03, ne10, ne11, ne12, nb10, nb11, nb12, nb13);
+                (cx, cdst, ne, ne00n, ne01n, ne02n, nb00, nb01, nb02, nb03, ne10, ne11, ne12, nb10, nb11, nb12, nb13,
+                 (int)y_off);
         }
-    }
-    if (!use_transposed) {
+    } else {
         const int64_t num_blocks = (ne + CUDA_CPY_BLOCK_SIZE - 1) / CUDA_CPY_BLOCK_SIZE;
         GGML_ASSERT(num_blocks < UINT_MAX);
         cpy_scalar<cpy_1_scalar<src_t, dst_t>><<<num_blocks, CUDA_CPY_BLOCK_SIZE, 0, stream>>>
-- 
