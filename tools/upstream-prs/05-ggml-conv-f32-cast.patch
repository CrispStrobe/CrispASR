From: <author>
Subject: [PATCH] ggml : cast F16 conv kernel to F32 in conv_1d / conv_1d_dw / conv_2d / conv_2d_dw

`ggml_compute_forward_mul_mat` requires src1 to be F32 when conversion
to vec_dot_type is needed:

    if (src1->type != vec_dot_type) {
        ...
        GGML_ASSERT(src1->type == GGML_TYPE_F32);

The conv graph builders in ggml.c hardcode `im2col_type = F16` and
feed the kernel weight in directly. When the weight is F16 (typical
for half-precision GGUFs) the resulting `MUL_MAT(F16, F16)` is
unsupported on a CPU backend whose `vec_dot_type` for F16 isn't F16
(see the companion patch that sets `vec_dot_type = F32` to avoid the
saturating F32 -> F16 quantize on long-tail activations).

Pick `im2col_type` based on whether either side is F32 (matching what
`ggml_conv_1d` already did before this patch was unified across the
four builders). When `im2col_type == F32` and the kernel is non-F32,
`ggml_cast` the kernel to F32 so the resulting MUL_MAT has F32 src1.

Bandwidth cost is real (extra F16 -> F32 cast per inference pass) but
unavoidable as long as upstream `mul_mat` rejects non-F32 src1 in the
type-conversion path.

diff --git a/ggml/src/ggml.c b/ggml/src/ggml.c
--- a/ggml/src/ggml.c
+++ b/ggml/src/ggml.c
@@ -4477,12 +4477,18 @@ struct ggml_tensor * ggml_conv_1d(
         int                   s0,
         int                   p0,
         int                   d0) {
-    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, 0, p0, 0, d0, 0, false, GGML_TYPE_F16); // [N, OL, IC * K]
+    // im2col output type follows whichever side is F32; cast the kernel to
+    // F32 too so the resulting MUL_MAT has F32 src1 (mul_mat's conversion
+    // path requires src1 to be F32).
+    const enum ggml_type im2col_type = (a->type == GGML_TYPE_F32 || b->type == GGML_TYPE_F32) ? GGML_TYPE_F32 : GGML_TYPE_F16;
+    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, 0, p0, 0, d0, 0, false, im2col_type); // [N, OL, IC * K]
+
+    struct ggml_tensor * a_mat = (im2col_type == GGML_TYPE_F32 && a->type != GGML_TYPE_F32) ?
+                                     ggml_cast(ctx, a, GGML_TYPE_F32) : a;

     struct ggml_tensor * result =
         ggml_mul_mat(ctx,
                 ggml_reshape_2d(ctx, im2col, im2col->ne[0], (im2col->ne[2] * im2col->ne[1])), // [N, OL, IC * K] => [N*OL, IC * K]
-                ggml_reshape_2d(ctx, a, (a->ne[0] * a->ne[1]), a->ne[2]));                    // [OC, IC, K] => [OC, IC * K]
+                ggml_reshape_2d(ctx, a_mat, (a_mat->ne[0] * a_mat->ne[1]), a_mat->ne[2]));    // [OC, IC, K] => [OC, IC * K]

     result = ggml_reshape_3d(ctx, result, im2col->ne[1], a->ne[2], im2col->ne[2]); // [N, OC, OL]

@@ -4511,9 +4517,13 @@ struct ggml_tensor * ggml_conv_1d_dw(
         int                   d0) {
     struct ggml_tensor * new_b = ggml_reshape_4d(ctx, b, b->ne[0], 1, b->ne[1], b->ne[2]);

-    struct ggml_tensor * im2col = ggml_im2col(ctx, a, new_b, s0, 0, p0, 0, d0, 0, false, GGML_TYPE_F16);
+    const enum ggml_type im2col_type = (a->type == GGML_TYPE_F32 || b->type == GGML_TYPE_F32) ? GGML_TYPE_F32 : GGML_TYPE_F16;
+    struct ggml_tensor * im2col = ggml_im2col(ctx, a, new_b, s0, 0, p0, 0, d0, 0, false, im2col_type);

-    struct ggml_tensor * result = ggml_mul_mat(ctx, im2col, a);
+    struct ggml_tensor * a_mat = (im2col_type == GGML_TYPE_F32 && a->type != GGML_TYPE_F32)
+                                     ? ggml_cast(ctx, a, GGML_TYPE_F32) : a;
+    struct ggml_tensor * result = ggml_mul_mat(ctx, im2col, a_mat);

     result = ggml_reshape_3d(ctx, result, result->ne[0], result->ne[2], 1);

@@ -4582,12 +4592,17 @@ struct ggml_tensor * ggml_conv_2d(
         int                   p1,
         int                   d0,
         int                   d1) {
-    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, s1, p0, p1, d0, d1, true, a->type); // [N, OH, OW, IC * KH * KW]
+    // Same kernel-cast policy as ggml_conv_1d: pick F32 im2col when either
+    // side is F32, cast the kernel to F32 to match.
+    const enum ggml_type im2col_type = (a->type == GGML_TYPE_F32 || b->type == GGML_TYPE_F32) ? GGML_TYPE_F32 : GGML_TYPE_F16;
+    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, s1, p0, p1, d0, d1, true, im2col_type); // [N, OH, OW, IC * KH * KW]
+
+    struct ggml_tensor * a_mat = (im2col_type == GGML_TYPE_F32 && a->type != GGML_TYPE_F32) ?
+                                     ggml_cast(ctx, a, GGML_TYPE_F32) : a;

     struct ggml_tensor * result =
         ggml_mul_mat(ctx,
                 ggml_reshape_2d(ctx, im2col, im2col->ne[0],  im2col->ne[3] * im2col->ne[2] * im2col->ne[1]), // [N, OH, OW, IC * KH * KW] => [N*OH*OW, IC * KH * KW]
-                ggml_reshape_2d(ctx, a, (a->ne[0] * a->ne[1] * a->ne[2]),  a->ne[3]));                       // [OC, IC, KH, KW] => [OC, IC * KH * KW]
+                ggml_reshape_2d(ctx, a_mat, (a_mat->ne[0] * a_mat->ne[1] * a_mat->ne[2]),  a_mat->ne[3]));   // [OC, IC, KH, KW] => [OC, IC * KH * KW]

     result = ggml_reshape_4d(ctx, result, im2col->ne[1], im2col->ne[2], im2col->ne[3], a->ne[3]); // [OC, N, OH, OW]
     result = ggml_cont(ctx, ggml_permute(ctx, result, 0, 1, 3, 2)); // [N, OC, OH, OW]
@@ -4711,14 +4726,18 @@ struct ggml_tensor * ggml_conv_2d_dw(
         int                   p1,
         int                   d0,
         int                   d1) {
+    const enum ggml_type im2col_type = (a->type == GGML_TYPE_F32 || b->type == GGML_TYPE_F32) ? GGML_TYPE_F32 : GGML_TYPE_F16;
     struct ggml_tensor * new_a = ggml_reshape_4d(ctx, a, a->ne[0], a->ne[1], 1, a->ne[2] * a->ne[3]);
     struct ggml_tensor * im2col = ggml_im2col(ctx, new_a,
                                         ggml_reshape_4d(ctx, b, b->ne[0], b->ne[1], 1, b->ne[2] * b->ne[3]),
-                                        s0, s1, p0, p1, d0, d1, true, GGML_TYPE_F16); // [N * IC, OH, OW, KH * KW]
+                                        s0, s1, p0, p1, d0, d1, true, im2col_type); // [N * IC, OH, OW, KH * KW]
     struct ggml_tensor * new_b = ggml_reshape_4d(ctx, im2col, im2col->ne[0], im2col->ne[2] * im2col->ne[1], b->ne[2], b->ne[3]); // [N * IC, OH, OW, KH * KW] => [N, IC, OH * OW, KH * KW]

     new_a = ggml_reshape_4d(ctx, new_a, (new_a->ne[0] * new_a->ne[1]), new_a->ne[2],  new_a->ne[3], 1);                       // [OC, 1, KH, KW] => [1, OC, 1, KH * KW]
-    struct ggml_tensor * result = ggml_mul_mat(ctx, new_a, new_b);
+    struct ggml_tensor * new_a_mat = (im2col_type == GGML_TYPE_F32 && new_a->type != GGML_TYPE_F32) ?
+                                         ggml_cast(ctx, new_a, GGML_TYPE_F32) : new_a;
+    struct ggml_tensor * result = ggml_mul_mat(ctx, new_a_mat, new_b);
     result = ggml_reshape_4d(ctx, result, im2col->ne[1], im2col->ne[2], b->ne[2], b->ne[3]); // [N, OC, OH, OW]

     return result;
